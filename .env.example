# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://rockyy.app
BETTER_AUTH_URL=https://rockyy.app
BETTER_AUTH_SECRET=generate-a-random-secret-here

# ── Database (Supabase) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ── Redis (Upstash) ─────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Auth Providers ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=
GITHUB_BOT_USER_ID=

# ── Linear ───────────────────────────────────────────────────────────────────
LINEAR_ACCESS_TOKEN=
LINEAR_WEBHOOK_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# ── Google Calendar ──────────────────────────────────────────────────────────
# Uses the same GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET from above.
# Get the refresh token from Google OAuth Playground (see README).
GOOGLE_CALENDAR_REFRESH_TOKEN=

# ── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
